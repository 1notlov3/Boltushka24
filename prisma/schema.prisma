generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Profile {
  id       String  @id @default(uuid())
  userId   String  @unique
  name     String
  imageUrl String  @db.Text
  email    String  @db.Text
  password String?

  status       UserStatus @default(OFFLINE)
  customStatus String?    @db.VarChar(80)
  lastSeenAt   DateTime?

  servers  Server[]
  members  Member[]
  channels Channel[]
  settings UserSettings?

  notificationsReceived Notification[] @relation("NotificationTarget")
  notificationsCreated  Notification[] @relation("NotificationActor")
  auditLogs             AuditLog[]     @relation("AuditLogActor")
  pushSubscriptions     PushSubscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model UserSettings {
  id String @id @default(uuid())

  profileId String  @unique
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  theme                String  @default("system")
  language             String  @default("ru")
  compactMode          Boolean @default(false)
  notificationsEnabled Boolean @default(true)
  soundEnabled         Boolean @default(true)
  showOnlineStatus     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Server {
  id          String @id @default(uuid())
  name        String
  imageUrl    String @db.Text
  inviteCode  String @unique
  description String? @db.VarChar(500)
  isPublic    Boolean @default(false)

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  members           Member[]
  channels          Channel[]
  channelCategories ChannelCategory[]
  serverRoles       ServerRole[]
  conversations     Conversation[]
  auditLogs         AuditLog[]
  notifications     Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId])
  @@index([isPublic, updatedAt])
}

enum MemberRole {
  ADMIN
  MODERATOR
  GUEST
}

enum UserStatus {
  ONLINE
  IDLE
  DND
  INVISIBLE
  OFFLINE
}

model Member {
  id   String     @id @default(uuid())
  role MemberRole @default(GUEST)

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  serverId String
  server   Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  messages       Message[]       @relation("MemberMessages")
  directMessages DirectMessage[] @relation("MemberDirectMessages")

  pinnedMessages       Message[]       @relation("MessagePinnedBy")
  pinnedDirectMessages DirectMessage[] @relation("DirectMessagePinnedBy")

  messageReactions       MessageReaction[]
  directMessageReactions DirectMessageReaction[]
  pollVotes              PollVote[]
  watchQueueVotes        WatchQueueVote[]
  savedMessages          SavedMessage[]
  savedDirectMessages    SavedDirectMessage[]
  channelReadStates      ChannelReadState[]
  conversationReadStates ConversationReadState[]

  conversationsInitiated Conversation[] @relation("MemberOne")
  conversationsReceived  Conversation[] @relation("MemberTwo")
  conversationsOwned     Conversation[] @relation("ConversationOwner")
  conversationParticipants ConversationParticipant[]
  serverRoles            MemberServerRole[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([profileId, serverId])
  @@index([profileId])
  @@index([serverId])
}

enum ChannelType {
  TEXT
  AUDIO
  VIDEO
}

model ChannelCategory {
  id       String @id @default(uuid())
  name     String
  position Int    @default(0)

  serverId String
  server   Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  channels Channel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([serverId, name])
  @@index([serverId, position])
}

model Channel {
  id       String      @id @default(uuid())
  name     String
  type     ChannelType @default(TEXT)
  topic    String?     @db.Text
  icon     String?     @db.VarChar(32)
  position Int         @default(0)
  slowModeSeconds Int   @default(0)

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  serverId String
  server   Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  categoryId String?
  category   ChannelCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  messages      Message[]
  readStates    ChannelReadState[]
  notifications Notification[]
  watchSession  WatchSession?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId])
  @@index([serverId])
  @@index([serverId, position])
  @@index([categoryId])
}

model Message {
  id      String  @id @default(uuid())
  content String  @db.Text
  fileUrl String? @db.Text

  memberId String
  member   Member @relation("MemberMessages", fields: [memberId], references: [id], onDelete: Cascade)

  channelId String
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  parentMessageId String?
  parentMessage   Message?  @relation("MessageReplies", fields: [parentMessageId], references: [id], onDelete: SetNull)
  replies         Message[] @relation("MessageReplies")

  pinned     Boolean   @default(false)
  pinnedAt   DateTime?
  pinnedById String?
  pinnedBy   Member?   @relation("MessagePinnedBy", fields: [pinnedById], references: [id], onDelete: SetNull)

  deleted Boolean @default(false)

  reactions     MessageReaction[]
  savedBy       SavedMessage[]
  notifications Notification[]
  poll          Poll?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([channelId, createdAt])
  @@index([memberId])
  @@index([parentMessageId])
  @@index([pinned])
}

model MessageReaction {
  id String @id @default(uuid())

  emoji String @db.VarChar(32)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([memberId, messageId, emoji])
  @@index([messageId])
  @@index([memberId])
}

model SavedMessage {
  id String @id @default(uuid())

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([memberId, messageId])
  @@index([memberId, createdAt])
  @@index([messageId])
}

enum ConversationType {
  DIRECT
  GROUP
}

enum ConversationParticipantRole {
  OWNER
  ADMIN
  MEMBER
}

model Conversation {
  id String @id @default(uuid())

  type     ConversationType @default(DIRECT)
  name     String? @db.VarChar(120)
  imageUrl String? @db.Text

  serverId String?
  server   Server? @relation(fields: [serverId], references: [id], onDelete: Cascade)

  ownerId String?
  owner   Member? @relation("ConversationOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  memberOneId String
  memberOne   Member @relation("MemberOne", fields: [memberOneId], references: [id], onDelete: Cascade)

  memberTwoId String
  memberTwo   Member @relation("MemberTwo", fields: [memberTwoId], references: [id], onDelete: Cascade)

  participants   ConversationParticipant[]
  directMessages DirectMessage[]
  readStates     ConversationReadState[]
  notifications  Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([memberOneId, memberTwoId])
  @@index([memberOneId])
  @@index([memberTwoId])
  @@index([type])
  @@index([serverId])
  @@index([ownerId])
}

model ConversationParticipant {
  id String @id @default(uuid())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  role ConversationParticipantRole @default(MEMBER)

  joinedAt    DateTime @default(now())
  leftAt      DateTime?
  mutedUntil  DateTime?
  archivedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([conversationId, memberId])
  @@index([memberId])
  @@index([conversationId])
  @@index([memberId, leftAt])
}

model DirectMessage {
  id      String  @id @default(uuid())
  content String  @db.Text
  fileUrl String? @db.Text

  memberId String
  member   Member @relation("MemberDirectMessages", fields: [memberId], references: [id], onDelete: Cascade)

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  parentDirectMessageId String?
  parentDirectMessage   DirectMessage?  @relation("DirectMessageReplies", fields: [parentDirectMessageId], references: [id], onDelete: SetNull)
  replies               DirectMessage[] @relation("DirectMessageReplies")

  pinned     Boolean   @default(false)
  pinnedAt   DateTime?
  pinnedById String?
  pinnedBy   Member?   @relation("DirectMessagePinnedBy", fields: [pinnedById], references: [id], onDelete: SetNull)

  deleted Boolean @default(false)

  reactions     DirectMessageReaction[]
  savedBy       SavedDirectMessage[]
  notifications Notification[]
  poll          Poll?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([memberId])
  @@index([conversationId, createdAt])
  @@index([parentDirectMessageId])
  @@index([pinned])
}

model DirectMessageReaction {
  id String @id @default(uuid())

  emoji String @db.VarChar(32)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  directMessageId String
  directMessage   DirectMessage @relation(fields: [directMessageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([memberId, directMessageId, emoji])
  @@index([directMessageId])
  @@index([memberId])
}

model SavedDirectMessage {
  id String @id @default(uuid())

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  directMessageId String
  directMessage   DirectMessage @relation(fields: [directMessageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([memberId, directMessageId])
  @@index([memberId, createdAt])
  @@index([directMessageId])
}

enum NotificationType {
  MENTION
  REPLY
  REACTION
  PIN
  DIRECT_MESSAGE
  SERVER_INVITE
  SYSTEM
}

model Notification {
  id   String           @id @default(uuid())
  type NotificationType
  read Boolean          @default(false)

  actorId String?
  actor   Profile? @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  targetId String
  target   Profile @relation("NotificationTarget", fields: [targetId], references: [id], onDelete: Cascade)

  serverId String?
  server   Server? @relation(fields: [serverId], references: [id], onDelete: Cascade)

  channelId String?
  channel   Channel? @relation(fields: [channelId], references: [id], onDelete: Cascade)

  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  messageId String?
  message   Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)

  directMessageId String?
  directMessage   DirectMessage? @relation(fields: [directMessageId], references: [id], onDelete: Cascade)

  metadata Json?

  createdAt DateTime @default(now())

  @@index([targetId, read, createdAt])
  @@index([actorId])
  @@index([serverId])
  @@index([channelId])
  @@index([conversationId])
  @@index([messageId])
  @@index([directMessageId])
}

model PushSubscription {
  id        String @id @default(uuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  endpoint   String @unique @db.Text
  keysAuth   String @db.Text
  keysP256dh String @db.Text

  createdAt DateTime @default(now())

  @@index([profileId])
}

model ChannelReadState {
  id String @id @default(uuid())

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  channelId String
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  lastReadAt DateTime @default(now())

  @@unique([memberId, channelId])
  @@index([channelId])
}

model ConversationReadState {
  id String @id @default(uuid())

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  lastReadAt DateTime @default(now())

  @@unique([memberId, conversationId])
  @@index([conversationId])
}

model ServerRole {
  id          String @id @default(uuid())
  name        String
  color       String @default("#6366f1")
  permissions Json
  position    Int @default(0)

  serverId String
  server   Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  members  MemberServerRole[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([serverId, name])
  @@index([serverId, position])
}

model MemberServerRole {
  id String @id @default(uuid())

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  roleId String
  role   ServerRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([memberId, roleId])
  @@index([memberId])
  @@index([roleId])
}

model AuditLog {
  id       String  @id @default(uuid())
  action   String
  targetId String?
  metadata Json?

  actorId String?
  actor   Profile? @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)

  serverId String
  server   Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([serverId, createdAt])
  @@index([actorId])
  @@index([targetId])
}

model WatchSession {
  id             String @id @default(uuid())
  channelId      String @unique
  channel        Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  currentVideoId String?
  currentTime    Float   @default(0)
  isPlaying      Boolean @default(false)
  updatedById    String?
  updatedByName  String?
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
  queue          WatchQueueItem[]

  @@index([channelId])
}

model WatchQueueItem {
  id          String @id @default(uuid())
  sessionId   String
  session     WatchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  videoId     String
  title       String?
  thumbnail   String?
  addedById   String
  addedByName String
  position    Int
  createdAt   DateTime @default(now())
  votes       WatchQueueVote[]

  @@index([sessionId, position])
}

model WatchQueueVote {
  id String @id @default(uuid())

  itemId String
  item   WatchQueueItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([itemId, memberId])
  @@index([memberId])
  @@index([itemId, createdAt])
}

model Poll {
  id              String @id @default(uuid())
  messageId       String? @unique
  message         Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)
  directMessageId String? @unique
  directMessage   DirectMessage? @relation(fields: [directMessageId], references: [id], onDelete: Cascade)
  question        String
  options         Json
  multiple        Boolean @default(false)
  closesAt        DateTime?
  createdAt       DateTime @default(now())
  votes           PollVote[]

  @@index([messageId])
  @@index([directMessageId])
}

model PollVote {
  id        String @id @default(uuid())
  pollId    String
  poll      Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  memberId  String
  member    Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  optionId  String
  createdAt DateTime @default(now())

  @@unique([pollId, memberId, optionId])
  @@index([memberId])
}

model LinkPreview {
  id          String @id @default(uuid())
  url         String @unique
  title       String?
  description String?
  image       String?
  fetchedAt   DateTime

  @@index([fetchedAt])
}
